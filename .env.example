YOUTUBE_API_KEY=your-youtube-api-key-here
YOUTUBE_CHANNEL_ID=your-youtube-channel-id-here
PORT=3000
USDA_API_KEY=your-usda-key-here
SERPAPI_KEY=your-serpapi-key-here
KLAVIYO_PRIVATE_API_KEY=your-klaviyo-private-api-key-here
# Klaviyo event profile:
# - free (default): only essential lifecycle/retention events
# - all: send every event wired in backend routes
# - none: disable Klaviyo event emission
# KLAVIYO_EVENT_PROFILE=free
# Optional strict override list (comma-separated). If set, only these events send:
# KLAVIYO_ENABLED_EVENTS=Account Created,Password Reset Requested,Message Received
# Legacy alias also supported by server code:
# KLAVIYOPRIVATEAPIKEY=your-klaviyo-private-api-key-here
# Public site URL for password reset links and email CTAs:
# APP_BASE_URL=https://odeology.up.railway.app
# Password reset link expiry in minutes:
# PASSWORD_RESET_TOKEN_TTL_MINUTES=60
# Neon / Postgres (recommended: paste the full Neon "Node.js" connection string here)
# DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require&channel_binding=require"

# Alternatively, use individual env vars (matches Neon's Node guide)
# PGHOST='[neon_hostname]'
# PGDATABASE='[dbname]'
# PGUSER='[user]'
# PGPASSWORD='[password]'
# PGPORT=5432

# Auth (sessions stored in Neon)
# SESSION_TTL_DAYS=30
# SESSION_COOKIE_NAME=sid
# COOKIE_SECURE=0

# Google OAuth (optional)
# Create credentials in Google Cloud Console and set an "Authorized redirect URI" to:
#   http://localhost:3000/api/auth/google/callback
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Admin dashboard (keep these out of client-side JS)
# ADMIN_USERNAME=Mason0205
# ADMIN_PASSCODE=4digitcode
# ADMIN_SESSION_TTL_DAYS=7
